        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(vehicle_http_requests_total{status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(vehicle_http_requests_total[5m])), 0.0001)",
          "refId": "A"
        }
      ],
      "title": "HTTP 5xx Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
