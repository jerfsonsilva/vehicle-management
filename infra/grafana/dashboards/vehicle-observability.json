      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(vehicle_http_request_duration_seconds_bucket[5m])) by (le))",
          "refId": "A"
        }
      ],
      "title": "HTTP p95 Latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit"
